{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JSON-RPC 2.0 MCP Protocol Messages",
  "type": "object",
  "required": ["jsonrpc"],
  "properties": {
    "jsonrpc": {
      "type": "string",
      "const": "2.0"
    }
  },
  "oneOf": [
    {
      "title": "Request Message",
      "required": ["method", "id"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["initialize", "tools/list", "tools/call", "roots/list"],
          "description": "roots/list is server-initiated: NetBeans sends this request to the client after initialize (if the client declared capabilities.roots) to learn the client's workspace root folder(s)."
        },
        "id": {
          "type": "integer"
        },
        "params": {
          "oneOf": [
            {
              "title": "Initialize Params",
              "type": "object",
              "properties": {
                "protocolVersion": {"type": "string"},
                "capabilities": {
                  "type": "object",
                  "properties": {
                    "roots": {"type": "object"}
                  }
                },
                "clientInfo": {
                  "type": "object",
                  "properties": {
                    "name": {"type": "string"},
                    "version": {"type": "string"}
                  }
                }
              }
            },
            {
              "title": "Tools/Call Params",
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "arguments": {"type": "object"}
              }
            },
            {
              "title": "Roots/List Params",
              "type": "object",
              "description": "No params - the server requests all of the client's declared workspace roots."
            }
          ]
        }
      }
    },
    {
      "title": "Response Message",
      "required": ["id"],
      "not": {"required": ["method"]},
      "properties": {
        "id": {
          "type": "integer"
        }
      },
      "oneOf": [
        {
          "title": "Success Response",
          "required": ["result"],
          "properties": {
            "result": {
              "oneOf": [
                {
                  "title": "Initialize Result",
                  "type": "object",
                  "properties": {
                    "protocolVersion": {"type": "string"},
                    "capabilities": {
                      "type": "object",
                      "properties": {
                        "tools": {
                          "type": "object",
                          "properties": {
                            "listChanged": {"type": "boolean"}
                          }
                        }
                      }
                    },
                    "serverInfo": {
                      "type": "object",
                      "properties": {
                        "name": {"type": "string"},
                        "version": {"type": "string"}
                      }
                    }
                  }
                },
                {
                  "title": "Tools/Call Result",
                  "type": "object",
                  "properties": {
                    "content": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": {"type": "string"},
                          "text": {"type": "string"}
                        }
                      }
                    }
                  }
                },
                {
                  "title": "Roots/List Result",
                  "description": "Sent by the client in response to a server-initiated roots/list request.",
                  "type": "object",
                  "properties": {
                    "roots": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "uri": {"type": "string", "description": "file:// URI of the workspace root"},
                          "name": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        },
        {
          "title": "Error Response",
          "required": ["error"],
          "properties": {
            "error": {
              "type": "object",
              "properties": {
                "code": {"type": "integer"},
                "message": {"type": "string"},
                "data": {}
              }
            }
          }
        }
      ]
    },
    {
      "title": "Notification Message",
      "required": ["method"],
      "not": {"required": ["id"]},
      "properties": {
        "method": {
          "type": "string",
          "enum": ["notifications/initialized", "ide_connected", "selection_changed", "diagnostics_changed", "log_event"]
        },
        "params": {
          "oneOf": [
            {
              "title": "IDE Connected Params",
              "type": "object",
              "properties": {
                "pid": {"type": "integer"}
              }
            },
            {
              "title": "Selection Changed Params",
              "type": "object",
              "properties": {
                "text": {"type": "string"},
                "filePath": {"type": "string"},
                "fileUrl": {"type": "string"},
                "selection": {
                  "type": "object",
                  "properties": {
                    "start": {
                      "type": "object",
                      "properties": {
                        "line": {"type": "integer"},
                        "character": {"type": "integer"}
                      }
                    },
                    "end": {
                      "type": "object",
                      "properties": {
                        "line": {"type": "integer"},
                        "character": {"type": "integer"}
                      }
                    },
                    "isEmpty": {"type": "boolean"}
                  }
                }
              }
            },
            {
              "title": "Diagnostics Changed Params",
              "type": "object",
              "properties": {
                "uris": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              }
            },
            {
              "title": "Log Event Params",
              "type": "object",
              "properties": {
                "eventName": {"type": "string"},
                "eventData": {"type": "object"}
              }
            }
          ]
        }
      }
    }
  ]
}